generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DDAPL
  CUSTOMER
}

enum POStatus {
  NEW
  PARTIALLY_COMPLETED
  COMPLETED
  ACTION_REQUIRED
}

enum ShipmentStatus {
  DRAFT
  INVOICE_UPLOADED
  POD_UPLOADED
  WAITING_APPROVAL
  ACCEPTED
  REJECTED
}


model User {
  id                 String          @id @default(uuid())
  name               String
  email              String          @unique
  password           String?         // Hashed password for NextAuth
  role               Role            @default(CUSTOMER)
  purchaseOrders     PurchaseOrder[] // For customers
  emailNotifications Boolean         @default(true)
  companyName        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model PurchaseOrder {
  id            String     @id @default(uuid())
  poNumber      String     @unique
  customerId    String
  customer      User       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  poFile        String     // File path or URL
  overallStatus POStatus   @default(NEW)
  shipments     Shipment[]
  uploadDate    DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([customerId])
  @@index([overallStatus])
}

model Shipment {
  id                String        @id @default(uuid())
  poId              String
  purchaseOrder     PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  shipmentNo        Int
  invoiceNo         String?
  invoicePdf        String?       // File path or URL
  podPdf            String?       // File path or URL
  status            ShipmentStatus @default(DRAFT)
  customerRemarks   String?
  visibleToCustomer Boolean       @default(false)
  createdDate       DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([poId])
  @@index([status])
}

model TrashItem {
  id          String   @id @default(uuid())
  entityType  String   // 'PO', 'SHIPMENT', 'DOCUMENT'
  entityName  String   
  filePaths   Json     // JSON array of file paths
  deletedAt   DateTime @default(now())
}


model AuditLog {
  id          String   @id @default(uuid())
  entityType  String   // "PurchaseOrder", "Shipment", etc.
  entityId    String
  action      String   // "CREATED", "UPDATED", "DELETED"
  oldValue    Json?
  newValue    Json?
  userId      String?  // ID of the user performing the action
  createdAt   DateTime @default(now())

  @@index([entityId])
  @@index([entityType, entityId])
}
